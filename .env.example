# ==============================================
# Database Configuration
# ==============================================
# Credentials for creating the database (Docker Compose)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_TO_STRONG_PASSWORD
POSTGRES_DB=axum_db

# Connection string for the API
# Format: postgres://<user>:<password>@<host>:<port>/<db_name>
# Docker Compose / container runtime:
# - DATABASE_URL should use host 'db'
# Local development (cargo run on your machine):
# - DATABASE_URL should use host 'localhost'
# Example local value:
# DATABASE_URL=postgres://postgres:CHANGE_ME_TO_STRONG_PASSWORD@localhost:5432/axum_db
DATABASE_URL=postgres://postgres:CHANGE_ME_TO_STRONG_PASSWORD@db:5432/axum_db
DB_POOL_MAX=5

# ==============================================
# Cache Configuration (Dragonfly / Redis)
# ==============================================
# Docker Compose / container runtime:
# - REDIS_URL should use host 'dragonfly'
# Local development (cargo run on your machine):
# - REDIS_URL should use host 'localhost'
# Example local value:
# REDIS_URL=redis://localhost:6379
REDIS_URL=redis://dragonfly:6379
CACHE_TTL_SECONDS=300

# ==============================================
# Server Configuration
# ==============================================
HOST=0.0.0.0
PORT=8080

# ==============================================
# Security Configuration
# ==============================================
# Generate a secret with: openssl rand -base64 32
JWT_SECRET=CHANGE_ME_TO_RANDOM_SECRET_KEY
ACCESS_TOKEN_EXPIRY_MINUTES=15
REFRESH_TOKEN_EXPIRY_DAYS=7

# ==============================================
# Middleware Configuration
# ==============================================
# CORS allowed origin (e.g., https://your-frontend.com)
CORS_ORIGIN=https://your-frontend-domain.com

# Rate Limiting (Per IP Address)
# Recommended: 300-600 requests per minute (5-10 req/s average)
# This allows for burst traffic from SPAs while preventing abuse.
RATE_LIMIT_REQUESTS=300
RATE_LIMIT_SECONDS=60
REQUEST_TIMEOUT_SECONDS=30

# ==============================================
# Benchmark Mode
# ==============================================
# Increase these values before load testing so middleware does not dominate results.
# Suggested benchmark settings:
# - RATE_LIMIT_REQUESTS=100000
# - RATE_LIMIT_SECONDS=60
# - REQUEST_TIMEOUT_SECONDS=60
# - CORS_ORIGIN=*        (only if you are testing from a browser or another origin)
#
# If you benchmark login/register endpoints, keep DATABASE_URL and REDIS_URL pointing
# to the running services for the mode you are testing:
# - Docker: db / dragonfly
# - Local: localhost / localhost
#
# To benchmark the built-in routes under /benchmark/*, set:
# ENABLE_BENCHMARK_ROUTES=true
# The routes stay disabled by default so production behavior does not change.

# Logging
LOG_LEVEL=info
